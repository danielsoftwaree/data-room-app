# Copy to .env and fill in real values. Never commit .env.

# PostgreSQL. Falls back to the local dev database when unset (dev only; required in production).
DATABASE_URL=postgres://dataroom:dataroom@localhost:5432/dataroom

# File blob storage driver: "db" (PostgreSQL bytea - zero-setup default for local dev)
# or "s3" (any S3-compatible bucket, e.g. Railway bucket in production).
STORAGE_DRIVER=db

# Required when STORAGE_DRIVER=s3 (take the values from the Railway bucket service).
# S3_ENDPOINT=https://bucket-endpoint.example.com
# S3_REGION=auto
# S3_BUCKET=dataroom
# S3_ACCESS_KEY_ID=xxxxxxxx
# S3_SECRET_ACCESS_KEY=xxxxxxxx

# Clerk (https://clerk.com) — auth is scaffolded but not implemented yet (see docs/auth-clerk.md).
# Get both keys from the Clerk dashboard (API Keys page).
VITE_CLERK_PUBLISHABLE_KEY=your_clerk_publishable_key
CLERK_SECRET_KEY=your_clerk_secret_key
