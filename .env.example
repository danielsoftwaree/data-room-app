# Copy to .env and fill in real values. Never commit .env.

# PostgreSQL. Falls back to the local dev database when unset (dev only; required in production).
DATABASE_URL=postgres://dataroom:dataroom@localhost:5432/dataroom

# Playwright real-mode tests use a dedicated database. The docker compose
# init script creates it on a fresh postgres volume.
E2E_DATABASE_URL=postgres://dataroom:dataroom@localhost:5432/dataroom_e2e

# HTTP port for the API (Railway injects PORT automatically).
# PORT=3000

# Optional absolute API origin for deployed web builds. Leave unset in local dev
# so Vite's /api proxy is used.
# VITE_API_URL=https://your-api-service.up.railway.app

# Comma-separated allowlist of browser origins. Defaults to the Vite dev
# origins in development; required in production.
# CORS_ORIGIN=https://your-web-app.example.com

# File blob storage driver: "db" (PostgreSQL bytea - zero-setup default for local dev)
# or "s3" (any S3-compatible bucket, e.g. Railway bucket in production).
STORAGE_DRIVER=db

# Required when STORAGE_DRIVER=s3 (take the values from the Railway bucket service).
# S3_ENDPOINT=https://bucket-endpoint.example.com
# S3_REGION=auto
# S3_BUCKET=dataroom
# S3_ACCESS_KEY_ID=xxxxxxxx
# S3_SECRET_ACCESS_KEY=xxxxxxxx

# Max pg pool connections for the API (default 10).
# DATABASE_POOL_MAX=10

# Web dev server: set to "false" to hit the real API through the Vite proxy
# instead of the MSW mock backend (this is what `bun run dev:real` does).
# VITE_ENABLE_MOCKS=false
