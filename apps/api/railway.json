{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "bun run build --filter=api"
  },
  "deploy": {
    "preDeployCommand": ["bun run --cwd packages/db db:migrate"],
    "startCommand": "bun run --cwd apps/api start:prod",
    "healthcheckPath": "/api/health",
    "restartPolicyType": "ON_FAILURE"
  }
}
